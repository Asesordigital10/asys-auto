            unsubscribeCargas = onSnapshot(cargasColl, (snap) => {
                historialCargas = snap.docs
                    .map(d => ({ id: d.id, ...d.data() }))
                    .sort((a, b) => b.fecha - a.fecha);
                renderizarApp();
            }, (err) => {
                showNotification("Error de acceso a Firestore.", 'error');
            });
        }

